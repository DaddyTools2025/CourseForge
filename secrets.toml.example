# CourseForge API 配置示例
# 使用前请将此文件重命名为 secrets.toml 并填入真实信息

[ai_config]
api_key = "sk-xxxxxxxxxxxxxxxx"  # 替换为您的 API Key
base_url = "https://api.example.com/v1"  # 替换为您的 API Base URL
model_name = "gemini-2.5-pro"  # 或 "gemini-2.5-flash"

# 配置说明:
# - api_key: 从 API 服务商获取的密钥
# - base_url: API 服务的基础 URL，必须以 /v1 结尾
# - model_name: 使用的模型名称
#   - gemini-2.5-pro: 高质量输出，推荐用于正式课程
#   - gemini-2.5-flash: 快速响应，适合测试和快速迭代
